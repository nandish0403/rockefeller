# Frontend env (Vercel)
# Set this in Vercel Project Settings -> Environment Variables
VITE_API_URL=https://rockefeller-production.up.railway.app

# Optional fallback used if VITE_API_URL is missing
VITE_API_FALLBACK_URL=https://rockefeller-production.up.railway.app

# Required for map tiles
VITE_MAPTILER_KEY=replace_with_your_key
