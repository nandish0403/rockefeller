MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rockefeller?retryWrites=true&w=majority
DATABASE_NAME=rockefeller
SECRET_KEY=change-this-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60 
REFRESH_TOKEN_EXPIRE_DAYS=7
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:5173,https://rockefeller-production.up.railway.app,https://rockefeller-jade.vercel.app
CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?vercel\.app$
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
RAINFALL_YELLOW_THRESHOLD_MM=150
RAINFALL_ORANGE_THRESHOLD_MM=250
RAINFALL_RED_THRESHOLD_MM=350
FORECAST_RAIN_YELLOW_THRESHOLD_MM=15
FORECAST_RAIN_ORANGE_THRESHOLD_MM=35
FORECAST_RAIN_RED_THRESHOLD_MM=65
BLAST_YELLOW_THRESHOLD=5
BLAST_ORANGE_THRESHOLD=10
CRACK_RISK_FLAG_THRESHOLD=0.4
CRACK_RISK_CRITICAL_THRESHOLD=0.7
WATER_REPORT_YELLOW_THRESHOLD=2
ZONE_PROXIMITY_ALERT_METERS=200
MODEL_ARTIFACTS_DIR=
CRACK_MODEL_URL=
MODEL_CACHE_DIR=/tmp/model_cache
CRACK_MODEL_PATH=/tmp/model_cache/crack_model.keras
MODEL_DOWNLOAD_TIMEOUT_SEC=300
DAILY_REFRESH_TIMEZONE=Asia/Kolkata
DAILY_REFRESH_HOUR=6
DAILY_REFRESH_MINUTE=0
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
