MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/geoalert
DATABASE_NAME=geoalert
SECRET_KEY=change-this-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
REDIS_URL=redis://localhost:6379
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
RAINFALL_YELLOW_THRESHOLD_MM=150
RAINFALL_ORANGE_THRESHOLD_MM=250
RAINFALL_RED_THRESHOLD_MM=350
BLAST_YELLOW_THRESHOLD=5
BLAST_ORANGE_THRESHOLD=10
CRACK_RISK_FLAG_THRESHOLD=0.4
CRACK_RISK_CRITICAL_THRESHOLD=0.7
WATER_REPORT_YELLOW_THRESHOLD=2
ZONE_PROXIMITY_ALERT_METERS=200
